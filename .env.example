# Dois ambientes, dois arquivos (ambos gitignorados):
#   .env       → PRODUÇÃO (Tōryū Bot + branch main do Neon; usado na VM e pelo npm start / npm run deploy)
#   .env.local → DEV (Tōryū Bot Dev + branch dev do Neon; usado pelo npm run dev / npm run deploy:dev)

# Token do bot (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=cole_o_token_aqui

# Application ID (Developer Portal > General Information)
CLIENT_ID=cole_o_application_id_aqui

# ID do seu servidor (clique direito no nome do servidor > Copiar ID do servidor)
GUILD_ID=cole_o_id_do_servidor_aqui

# Connection string do Neon Postgres (Dashboard do Neon > Connect)
DATABASE_URL=cole_a_connection_string_aqui
