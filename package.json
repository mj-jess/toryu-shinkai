{
  "name": "familia-bot",
  "version": "1.0.0",
  "description": "Bot de administração do servidor da família (GTA RP)",
  "type": "module",
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "deploy": "tsx --env-file=.env src/deploy-commands.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "discord.js": "^14.27.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^3.2.7"
  }
}
