{
  "name": "familia-bot",
  "version": "1.0.0",
  "description": "Bot de administração do servidor da família (GTA RP)",
  "type": "module",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx --env-file=.env.local src/index.ts",
    "deploy": "tsx --env-file=.env src/deploy-commands.ts",
    "deploy:dev": "tsx --env-file=.env.local src/deploy-commands.ts",
    "db:generate": "drizzle-kit generate",
    "seed:dev": "tsx --env-file=.env.local src/seed-dev.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "discord.js": "^14.27.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^3.2.7"
  }
}
