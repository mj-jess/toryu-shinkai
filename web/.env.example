# Dashboard — variáveis de ambiente (copie para .env.local e preencha)

# Connection string do Neon (branch dev localmente; branch main na Vercel)
DATABASE_URL=

# Auth.js — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# OAuth do Discord (Developer Portal → aplicação → OAuth2)
# Localmente use o app DEV; na Vercel use o app de PRODUÇÃO.
# Não esqueça de cadastrar a redirect URL: <origin>/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# IDs do Discord autorizados a entrar no painel (separados por vírgula)
ALLOWED_DISCORD_IDS=
